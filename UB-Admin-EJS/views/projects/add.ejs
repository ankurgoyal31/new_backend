<div class="container-fluid py-4">
<div class="card shadow-sm border-0">
<div class="card-header bg-white fw-bold fs-5">
  Add New Project
</div>

<div class="card-body">

<form action="/projects/add" method="POST" enctype="multipart/form-data">

<!-- ================= BASIC INFO ================= -->

<h5 class="text-primary mb-3">Basic Information</h5>

<div class="row">

  <div class="col-md-6 mb-3">
    <label>Project Name *</label>
    <input type="text" name="name" class="form-control" required>
  </div>

  <div class="col-md-6 mb-3">
    <label>Address</label>
    <input type="text" name="address" class="form-control">
  </div>

  <div class="col-md-6 mb-3">
    <label>Category *</label>
    <select name="category" class="form-control" required>
      <option value="">Select Category</option>
      <% config.categories.forEach(function(cat){ %>
        <option value="<%= cat %>"><%= cat %></option>
      <% }) %>
    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label>Location *</label>
    <select name="location" class="form-control" required>
      <option value="">Select Location</option>
      <% config.locations.forEach(function(loc){ %>
        <option value="<%= loc %>"><%= loc %></option>
      <% }) %>
    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label>Price Range *</label>
    <select name="priceRange" class="form-control" required>
      <option value="">Select Price</option>
      <% config.priceRanges.forEach(function(price){ %>
        <option value="<%= price %>"><%= price %></option>
      <% }) %>
    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label>Status</label>
    <select name="status" class="form-control">
      <% config.statusOptions.forEach(function(status){ %>
        <option value="<%= status %>"><%= status %></option>
      <% }) %>
    </select>
  </div>

  <div class="col-md-6 mb-3">
    <label>Bedrooms</label>
    <input type="text" name="bedrooms" class="form-control" placeholder="e.g. 2, 3 BHK">
  </div>

  <div class="col-md-6 mb-3">
    <label>Area</label>
    <input type="text" name="area" class="form-control" placeholder="e.g. 1000 sq ft,Acres">
  </div>

   <div class="col-md-6 mb-3">
    <label>Rera Number</label>
    <input type="text" name="reraNumber" class="form-control" placeholder="e.g. Rera-12345">
  </div>

</div>

<hr>

<!-- ================= HERO ================= -->

<h5 class="text-primary mb-3">Hero Section</h5>

<div class="row">
  <div class="col-md-4 mb-3">
    <label>Hero Image 1 *</label>
    <input type="file" name="heroImage1" class="form-control" required>
  </div>

  <div class="col-md-4 mb-3">
    <label>Hero Image 2</label>
    <input type="file" name="heroImage2" class="form-control">
  </div>

  <div class="col-md-4 mb-3">
    <label>Hero Image 3</label>
    <input type="file" name="heroImage3" class="form-control">
  </div>
</div>

<hr>

<!-- ================= MAP LINK ================= -->

<h5 class="text-primary mb-3">Location Map</h5>

<div class="mb-3">
  <label>Google Map Link</label>
  <input type="text" name="locationMapLink" class="form-control"
         placeholder="Paste Google Map link">
</div>

<hr>

<h5 class="text-primary mb-3">Hero Section</h5>

<hr>

<!-- ================= VIDEO ================= -->
 
<h5 class="text-primary mb-3">Project Video</h5>

<div class="mb-3">
  <label>Upload Video</label> 
  <input type="file" name="projectVideo" class="form-control" accept="video/*">
</div>

<hr>
<!-- ================= MULTI IMAGE SECTIONS ================= -->

<h5 class="text-primary mb-3">Project Sections</h5>

<!-- MASTER PLAN -->
<div class="mb-3">
  <label>Plan</label>
  <div id="masterPlanWrapper"></div>
  <button type="button" class="btn btn-sm btn-secondary"
    onclick="addImageField('masterPlanWrapper','masterPlanImages')">
    + Add Image
  </button>
</div>

<!-- FLOOR PLAN -->
<div class="mb-3">
  <label>AMENITIES</label>
  <div id="floorPlanWrapper"></div>
  <button type="button" class="btn btn-sm btn-secondary"
    onclick="addImageField('floorPlanWrapper','floorPlanImages')">
    + Add Image
  </button>
</div>

<!-- EXCLUSIVE CLUB -->
<!-- <div class="mb-3">
  <label>GALLARY</label>
  <div id="exclusiveClubWrapper"></div>
  <button type="button" class="btn btn-sm btn-secondary"
    onclick="addImageField('exclusiveClubWrapper','exclusiveClubImages')">
    + Add Image
  </button>
</div> -->

<!-- FACILITIES -->
<div class="mb-3">
  <label>GALLARY</label>
  <div id="facilitiesWrapper"></div>
  <button type="button" class="btn btn-sm btn-secondary"
    onclick="addImageField('facilitiesWrapper','facilitiesNearbyImages')">
    + Add Image
  </button>
</div>

<!-- CONSTRUCTION -->
<!-- <div class="mb-3">
  <label>Construction Update</label>
  <div id="constructionWrapper"></div>
  <button type="button" class="btn btn-sm btn-secondary"
    onclick="addImageField('constructionWrapper','constructionUpdateImages')">
    + Add Image
  </button> 
</div> -->

<hr>

<!-- ================= CUSTOM SECTIONS ================= -->

<h5 class="text-primary mb-3">Custom Sections</h5>

<div id="customSectionWrapper"></div>

<button type="button" class="btn btn-secondary btn-sm mb-3" onclick="addSection()">
  + Add Section 
</button>

<hr>

<!-- ================= FEATURES ================= -->

<h5 class="text-primary mb-3">Features</h5>

<div id="areaWrapper"></div>
<button type="button" class="btn btn-sm btn-secondary mb-3"
onclick="addFeature('areaWrapper','areaAndLot')">
+ Add AREA & LOT
</button>

<div id="interiorWrapper"></div>
<button type="button" class="btn btn-sm btn-secondary mb-3"
onclick="addFeature('interiorWrapper','interior')">
+ Add Interior
</button>

<div id="exteriorWrapper"></div>
<button type="button" class="btn btn-sm btn-secondary mb-3"
onclick="addFeature('exteriorWrapper','exterior')">
+ Add Exterior
</button>
<hr>

<% function renderFeatures(title, field, wrapperId){ %>

<h5 class="text-primary mb-3"><%= title %></h5>

<div id="<%= wrapperId %>">

  <% (project[field] || []).forEach(item => { %>
    <div class="input-group mb-2 feature-row">
      <input type="text"
        name="<%= field %>"
        value="<%= item.title %>"
        class="form-control">
      <button type="button" class="btn btn-danger remove-btn">Remove</button>
    </div>
  <% }) %>

</div>
<% } %>
<!-- ================= HIGHLIGHTS ================= -->

<h5 class="text-primary mb-3">Highlights</h5>

<div id="highlightWrapper"></div>
<button type="button" class="btn btn-sm btn-secondary mb-3" onclick="addHighlight()">
  + Add Highlight
</button>

<hr>

<!-- ================= FAQ ================= -->

<h5 class="text-primary mb-3">FAQ</h5>

<div id="faqWrapper"></div>
<button type="button" class="btn btn-sm btn-secondary mb-3" onclick="addFaq()">
  + Add FAQ
</button>

<hr>

<button type="submit" class="btn btn-primary px-4">
  Save Project
</button>

<a href="/projects" class="btn btn-secondary">
  Cancel
</a>

</form>
</div>
</div>
</div>

<script>

/* ================= MULTI IMAGE ADD ================= */
function addImageField(wrapperId, fieldName) {
  const div = document.createElement('div');
  div.classList.add('input-group','mb-2');

  div.innerHTML = `
    <input type="file" name="${fieldName}" class="form-control">
    <button type="button" class="btn btn-danger remove-btn">X</button>
  `;

  document.getElementById(wrapperId).appendChild(div);
}

/* ================= CUSTOM SECTION ================= */
function addSection() {
  const div = document.createElement('div');
  div.classList.add('border','p-3','mb-3');

  div.innerHTML = `
    <input type="text" name="customSectionTitle" class="form-control mb-2" placeholder="Section Title">

    <div class="custom-img-wrapper"></div>

    <button type="button"
      class="btn btn-sm btn-secondary mb-2"
      onclick="addImageToCustom(this)">
      + Add Image
    </button>

    <button type="button" class="btn btn-danger btn-sm remove-btn">Remove Section</button>
  `;

  document.getElementById('customSectionWrapper').appendChild(div);
}

/* custom section images */
function addImageToCustom(btn){
  const wrapper = btn.parentElement.querySelector('.custom-img-wrapper');

  const input = document.createElement('input');
  input.type = 'file';
  input.name = 'customSectionImages';
  input.classList.add('form-control','mb-2');

  wrapper.appendChild(input);
}

/* ================= FEATURES ================= */
function addFeature(wrapperId, fieldName) {
  const div = document.createElement('div');
  div.classList.add('input-group','mb-2');

  div.innerHTML = `
    <input type="text" name="${fieldName}" class="form-control">
    <button type="button" class="btn btn-danger remove-btn">Remove</button>
  `;

  document.getElementById(wrapperId).appendChild(div);
}

/* ================= HIGHLIGHT ================= */
function addHighlight() {
  const div = document.createElement('div');
  div.classList.add('row','mb-3');

  div.innerHTML = `
    <div class="col-md-5">
      <input type="text" name="highlightTitle" class="form-control">
    </div>
    <div class="col-md-5">
      <input type="file" name="highlightImages" class="form-control">
    </div>
    <div class="col-md-2">
      <button type="button" class="btn btn-danger w-100 remove-btn">X</button>
    </div>
  `;

  document.getElementById('highlightWrapper').appendChild(div);
}

/* ================= FAQ ================= */
function addFaq() {
  const div = document.createElement('div');
  div.classList.add('border','p-3','mb-3');

  div.innerHTML = `
    <input type="text" name="faqQuestion" class="form-control mb-2">
    <textarea name="faqAnswer" class="form-control mb-2"></textarea>
    <button type="button" class="btn btn-danger btn-sm remove-btn">Remove</button>
  `;

  document.getElementById('faqWrapper').appendChild(div);
}

/* ================= REMOVE ================= */
document.addEventListener("click", function(e){
  if(e.target.classList.contains("remove-btn")){
    e.target.closest('.input-group, .row, .border')?.remove();
  }
});

</script>

<script>

function addFeature(wrapperId, fieldName) {

  const div = document.createElement('div');

  div.className = 'input-group mb-2 feature-row';

  div.innerHTML = `
    <input
      type="text"
      name="${fieldName}"
      class="form-control">

    <button
      type="button"
      class="btn btn-danger remove-btn">
      Remove
    </button>
  `;

  document
    .getElementById(wrapperId)
    .appendChild(div);
}

</script>

<div class="container-fluid">
  <div class="card shadow-sm border-0">
    <div class="card-header bg-white fw-bold">
      Edit Blog
    </div>
    <div class="card-body">

      <form action="/blogs/edit/<%= blog._id %>?_method=PUT" method="POST">

        <div class="mb-3">
          <label class="form-label">Title</label>
          <input type="text" 
                 name="title" 
                 class="form-control" 
                 value="<%= blog.title %>"  
                 required>
        </div>
 
        <div class="mb-3">
          <label class="form-label">Author</label>
          <input type="text" 
                 name="author" 
                 class="form-control" 
                 value="<%= blog.author %>" 
                 required>
        </div>

        <div class="mb-3">
          <label class="form-label">Content</label>
          <textarea name="content" 
                    rows="6" 
                    class="form-control" 
                    required><%= blog.content %></textarea>
        </div>

        <button type="submit" class="btn btn-primary">
          Update Blog
        </button>

        <a href="/blogs" class="btn btn-secondary">
          Cancel
        </a>

      </form>

    </div>
  </div>
</div>

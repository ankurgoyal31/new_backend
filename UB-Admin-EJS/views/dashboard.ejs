<div class="row g-4">

    <div class="col-md-4">
        <div class="stat-card">
            <h6>Total Blogs</h6>
            <h3><%= blogCount %></h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-card">
            <h6>Total Projects</h6>
            <h3><%= projectCount %></h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-card">
            <h6>Total Contacts</h6>
            <h3><%= contactCount %></h3>
        </div>
    </div>

</div>

<div class="row g-4 mt-2">
    <div class="col-md-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-primary"><i class="bi bi-building"></i> CSR Management</h5>
                <% if (typeof csrExists !== 'undefined' && csrExists) { %>
                    <a href="/CSR/edit" class="btn btn-primary"><i class="bi bi-pencil-square"></i> Edit CSR</a>
                <% } %>
            </div>
            <div class="card-body">
                <p class="text-muted mb-0">Manage the Corporate Social Responsibility page content, images, and galleries from here.</p>
            </div>
        </div>
    </div>
</div>
